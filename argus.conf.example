# Argus Configuration File
# Переименуйте в argus.conf и заполните своими данными

# === ТЕЛЕГРАМ (опционально) ===
# TELEGRAM_BOT_TOKEN=""
# TELEGRAM_CHAT_ID=""

# === API КЛЮЧИ (опционально) ===
# SHODAN_API=""
# VIRUSTOTAL_API=""
# SECURITYTRAILS_API=""
# HUNTER_API=""
# AI_API_KEY=""

# === ОБЩЕЕ ===
THREADS=50
TIMEOUT=30

# === SCOPE ===
DEFAULT_SCOPE=""
AUTO_SCOPE=true

# === C2 ===
C2_PORT=8443
C2_SSL=true
C2_JITTER_MIN=1
C2_JITTER_MAX=5

# === ЛОГИРОВАНИЕ ===
LOG_LEVEL=INFO
LOG_DIR=~/argus_logs
LOG_MAX_SIZE=10MB

# === СКРЫТНОСТЬ ===
TOR_ENABLED=false
JITTER_ENABLED=true
STEALTH_MODE=false
