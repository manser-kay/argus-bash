#!/bin/bash
# Argus Unified CLI — одна команда для всего

VERSION="49.0"
ARGUS_DIR="$HOME"

case "${1:-help}" in
    scan)
        SCOPE="${2:-}" $ARGUS_DIR/argus.sh "${3:-$2}"
        ;;
    passive)
        SCOPE="${3:-}" python3 $ARGUS_DIR/argus_passive.py ${2:-9990} &
        echo "[+] Passive: http://127.0.0.1:${2:-9990}"
        ;;
    c2)
        python3 $ARGUS_DIR/argus_https_c2.py ${2:-8443}
        ;;
    loot)
        $ARGUS_DIR/auto_loot.sh
        ;;
    poc)
        python3 $ARGUS_DIR/poc_generator.py "$2" "$3" "$4"
        ;;
    cvss)
        python3 $ARGUS_DIR/cvss_calc.py "$2" "$3"
        ;;
    escalate)
        $ARGUS_DIR/argus_escalate.sh
        ;;
    spread)
        $ARGUS_DIR/argus_spread.sh "$2" "$3"
        ;;
    stealth)
        source $ARGUS_DIR/argus_stealth.sh
        $ARGUS_DIR/argus.sh "$2"
        ;;
    console)
        $ARGUS_DIR/argus_console.sh
        ;;
    update)
        $ARGUS_DIR/argus_update.sh
        ;;
    status)
        echo "[ARGUS v$VERSION]"
        pgrep -f "argus_passive" >/dev/null && echo "  Passive: ✅" || echo "  Passive: ❌"
        pgrep -f "argus_https_c2" >/dev/null && echo "  C2: ✅" || echo "  C2: ❌"
        ls $ARGUS_DIR/argus_scan_* 2>/dev/null | tail -1 | xargs -I{} echo "  Last scan: {}"
        ;;
    version|--version|-v)
        echo "Argus v$VERSION — Red Team Framework"
        ;;
    help|--help|-h|*)
        echo "Argus v$VERSION — Unified Red Team CLI"
        echo ""
        echo "Команды:"
        echo "  argus scan [scope] <target>    — Полное сканирование"
        echo "  argus passive [port]           — Пассивный сканер"
        echo "  argus c2 [port]                — C2 сервер"
        echo "  argus loot                     — Собрать добычу"
        echo "  argus poc <type> <url> <pl>    — Сгенерировать PoC"
        echo "  argus cvss [AV] [VC]          — CVSS калькулятор"
        echo "  argus escalate                 — Эскалация привилегий"
        echo "  argus spread <subnet>          — Lateral Movement"
        echo "  argus stealth <target>         — Скрытный режим"
        echo "  argus console                  — Интерактивная консоль"
        echo "  argus update                   — Обновление"
        echo "  argus status                   — Статус"
        echo "  argus version                  — Версия"
        ;;
esac
